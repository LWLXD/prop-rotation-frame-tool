PORT=4000
VITE_API_BASE_URL=http://localhost:4000
STORAGE_ROOT=./storage
DATA_ROOT=./data

# 本地开发默认使用 mock 视频生成；接入火山方舟后改为 false 并填写 ARK_*。
SEEDANCE_MOCK=true
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=
ARK_MODEL_ID=doubao-seedance-2-0-260128
ARK_POLL_INTERVAL_SECONDS=5
ARK_MAX_POLL_SECONDS=900
ARK_REQUEST_TIMEOUT_SECONDS=60

# OSS 只用于参考图片和可选参考视频的临时公网 URL。
OSS_ENABLED=false
OSS_REGION=oss-cn-beijing
OSS_BUCKET=blueultra-ai
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BASE_URL=https://blueultra-ai.oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ALLOWED_ROOT_PREFIX=wanglin/
OSS_TEMP_PREFIX=wanglin/seedance2/temp/
OSS_TEMP_TTL_HOURS=24

# 设置后会使用 BullMQ；未设置时 worker 使用本地轮询队列，方便无 Redis 开发。
REDIS_URL=
REMBG_SERVICE_URL=http://localhost:8001
