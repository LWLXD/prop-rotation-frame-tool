PORT=4000
VITE_API_BASE_URL=http://localhost:4000
STORAGE_ROOT=./storage
DATA_ROOT=./data

# 本地开发默认使用 mock 视频生成；接入火山方舟后改为 false 并填写 ARK_*。
SEEDANCE_MOCK=true
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=
ARK_MODEL_ID=doubao-seedance-2-0-260128
ARK_POLL_INTERVAL_SECONDS=5
ARK_MAX_POLL_SECONDS=900
ARK_REQUEST_TIMEOUT_SECONDS=60

# 设置后会使用 BullMQ；未设置时 worker 使用本地轮询队列，方便无 Redis 开发。
REDIS_URL=
REMBG_SERVICE_URL=http://localhost:8001
